@model List<SalesPulseCRM.Application.DTOs.LeadResponseDto>

@{
    ViewBag.Title = "Leads";
}

<link href="~/css/LeadController/GetAllLeads.css" rel="stylesheet" />

<div class="container-fluid py-3">

    <!-- 🔍 FILTER BAR -->
    <div class="lead-filter-bar">

        <input type="text" id="searchInput" placeholder="Search leads..." />

        <select id="statusFilter">
            <option value="">Status</option>
            @foreach (var s in ViewBag.LeadStatus)
            {
                <option value="@s.StatusName">@s.StatusName</option>
            }
        </select>

        <select id="projectFilter">
            <option value="">Project</option>
            @foreach (var project in ViewBag.Projects)
            {
                <option value="@project.ProjectId">
                    @project.ProjectName (@project.Location)
                </option>
            }
        </select>

        <select id="cityFilter">
            <option value="">City</option>
            @foreach (var c in Model
                        .Where(x => !string.IsNullOrEmpty(x.CityName))
                        .Select(x => x.CityName)
                        .Distinct())
            {
                <option value="@c">@c</option>
            }
        </select>
        <div class="date-filter">
            <span>From:</span>
            <input type="date" id="fromDate" />
            <span>To:</span>
            <input type="date" id="toDate" />
        </div>
    </div>

    <!-- 📦 LEADS -->
    <div class="row" id="leadContainer">

        @foreach (var lead in Model ?? new List<SalesPulseCRM.Application.DTOs.LeadResponseDto>())
        {
            var status = lead.LeadType?.ToLower() ?? "new";

            <div class="col-6 col-md-6 col-xl-4 lead-card-wrapper"
                 data-status="@lead.LeadType?.ToLower()"
                 data-project="@lead.ProjectId"
                 data-date="@lead.CreatedDate.ToString("yyyy-MM-dd")" data-city="@lead.CityName?.ToLower()">

                <div class="lead-card">

                    <!-- HEADER -->
                    <div class="lead-top">

                        <div class="d-flex align-items-center gap-3">
                            <div class="lead-avatar">
                                @lead.CustomerName.Substring(0, 1)
                            </div>

                            <div>
                                <div class="lead-name">@lead.CustomerName</div>
                                <div class="lead-email">@lead.Email</div>
                            </div>
                        </div>

                        <span class="lead-status @status">
                            @(lead.LeadType ?? "New")
                        </span>

                    </div>

                    <!-- BODY -->
                    <div class="lead-body">

                        <div class="lead-row">
                            <a href="tel:@lead.Phone" class="lead-phone">
                                📞 @lead.Phone
                            </a>
                            <span>🏙 @(lead.CityName ?? "-")</span>
                        </div>

                        <div class="lead-row">
                            <span>🏢 @(lead.ProjectName ?? "-")</span>
                            <span>📅 @lead.CreatedDate.ToString("dd MMM yyyy")</span>
                        </div>

                    </div>

                    <!-- ACTIONS -->
                    <div class="lead-actions">
                        <button class="btn-edit">Edit</button>
                    </div>

                </div>

            </div>
        }

    </div>

</div>
<script>
    const search = document.getElementById("searchInput");
    const statusFilter = document.getElementById("statusFilter");
    const projectFilter = document.getElementById("projectFilter");
    const fromDate = document.getElementById("fromDate");
    const toDate = document.getElementById("toDate");
    const cityFilter = document.getElementById("cityFilter");

    function filterLeads() {
        let searchValue = search.value.toLowerCase();
        let statusValue = statusFilter.value.toLowerCase();
        let projectValue = projectFilter.value;
        let cityValue = cityFilter.value.toLowerCase();

        let from = fromDate.value ? new Date(fromDate.value) : null;
        let to = toDate.value ? new Date(toDate.value) : null;

        document.querySelectorAll(".lead-card-wrapper").forEach(card => {

            let text = card.innerText.toLowerCase();
            let status = (card.dataset.status || "").toLowerCase();
            let project = card.dataset.project || "";
            let city = (card.dataset.city || "").toLowerCase();
            let dateStr = card.dataset.date;

            let cardDate = dateStr ? new Date(dateStr) : null;

            let matchSearch = text.includes(searchValue);
            let matchStatus = !statusValue || status.includes(statusValue);
            let matchProject = !projectValue || project == projectValue;
            let matchCity = !cityValue || city.includes(cityValue);

            let matchDate = true;
            if (cardDate) {
                if (from && cardDate < from) matchDate = false;
                if (to && cardDate > to) matchDate = false;
            }

            card.style.display =
                (matchSearch && matchStatus && matchProject && matchCity && matchDate)
                    ? ""
                    : "none";
        });
    }

    // EVENTS
    search.addEventListener("keyup", filterLeads);
    statusFilter.addEventListener("change", filterLeads);
    projectFilter.addEventListener("change", filterLeads);
    cityFilter.addEventListener("change", filterLeads);
    fromDate.addEventListener("change", filterLeads);
    toDate.addEventListener("change", filterLeads);
</script>