@model List<SalesPulseCRM.Application.DTOs.LeadResponseDto>

@{
    ViewBag.Title = "Leads";
}

<!-- ✅ DATATABLE CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
<link href="~/css/LeadController/GetAllLeads.css" rel="stylesheet" asp-append-version="true"/>

<div class="container-fluid py-3">

    <div class="table-responsive">
        <table id="leadTable" class=" table-hover align-middle w-100">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>City</th>
                    <th>Project</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th style="width:120px;">Action</th>
                </tr>

            </thead>

            <tbody>
                @foreach (var lead in Model)
                {
                    <tr>
                        <td class="fw-semibold">@lead.CustomerName</td>

                        <td>
                           @lead.Phone
                        </td>

                        <td>@lead.CityName</td>

                        <td>@lead.ProjectName</td>

                        <td>
                            <span class="badge status-@lead.LeadType?.ToLower()">
                                @lead.LeadType
                            </span>
                        </td>

                        <td>@lead.CreatedDate.ToString("dd MMM yyyy")</td>
                        <td class="d-flex gap-2">

                            <!-- CALL -->
                            <a href="tel:@lead.Phone" class="btn-action call-btn" title="Call">
                                <i class="bi bi-telephone"></i>
                            </a>

                            <!-- WHATSAPP -->
                            <a href="https://wa.me/@lead.Phone" target="_blank" class="btn-action whatsapp-btn" title="WhatsApp">
                                <i class="bi bi-whatsapp"></i>
                            </a>

                            <!-- EDIT -->
                            <button class="btn-action edit-btn" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </button>

                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

</div>

<!-- ✅ MOBILE CARDS -->
<div class="lead-cards d-md-none">
    @foreach (var lead in Model)
    {
        <div class="lead-card">
            <div class="lead-header">
                <h6>@lead.CustomerName</h6>
                <span class="badge status-@lead.LeadType?.ToLower()">
                    @lead.LeadType
                </span>
            </div>

            <div class="lead-body">
                <p><i class="bi bi-telephone"></i> @lead.Phone</p>
                <p><i class="bi bi-geo-alt"></i> @lead.CityName</p>
                <p><i class="bi bi-building"></i> @lead.ProjectName</p>
                <p class="text-muted">
                    <i class="bi bi-calendar"></i>
                    @lead.CreatedDate.ToString("dd MMM yyyy")
                </p>
            </div>

            <div class="lead-actions">
                <a href="tel:@lead.Phone" class="btn-action call-btn">
                    <i class="bi bi-telephone"></i>
                </a>

                <a href="https://wa.me/@lead.Phone" target="_blank" class="btn-action whatsapp-btn">
                    <i class="bi bi-whatsapp"></i>
                </a>

                <button class="btn-action edit-btn">
                    <i class="bi bi-pencil"></i>
                </button>
            </div>
        </div>
    }
</div>

<!-- ✅ jQuery (required) -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<!-- ✅ DataTables -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<!-- ✅ INIT -->
<script>
    $(document).ready(function () {
        $('#leadTable').DataTable({
            responsive: true,
            pageLength: 10,
            lengthMenu: [10, 25, 50, 100],
            ordering: true,
            autoWidth: false,
            language: {
                search: "Search:",
                lengthMenu: "Show _MENU_ entries",
                info: "Showing _START_ to _END_ of _TOTAL_ leads",
                paginate: {
                    next: "→",
                    previous: "←"
                }
            }
        });
    });
</script>