@using SalesPulseCRM.Domain.Enum
@model SalesPulseCRM.Application.DTOs.LeadEditViewModel

@{
    ViewBag.Title = "Edit Lead";
}

<link href="~/css/LeadController/LeadUpdate.css" rel="stylesheet"  asp-append-version="true"/>

<div class="container-fluid py-3">

    <div class="row g-3">

        <!-- 🟦 LEFT: LEAD INFO -->
        <div class="col-lg-4">
            <div class="crm-card lead-info-card">

                <div class="lead-header">
                    <h5>@Model.CustomerName</h5>
                    <span class="badge status-@Model.LeadType?.ToLower()">
                        @Model.LeadType
                    </span>
                </div>

                <div class="lead-meta">
                    <p><i class="bi bi-telephone"></i> @Model.Phone</p>
                    <p><i class="bi bi-envelope"></i> @Model.Email</p>
                    <p><i class="bi bi-building"></i> @Model.ProjectName</p>
                    <p><i class="bi bi-geo-alt"></i> @Model.CityName</p>
                    <p><i class="bi bi-person"></i> @Model.CurrentAssignToName</p>
                </div>

                <div class="lead-footer">
                    Created: @Model.CreatedDate.ToString("dd MMM yyyy")
                </div>

            </div>
        </div>

        <!-- 🟧 RIGHT: ACTION PANEL -->
        <div class="col-lg-8">

            <!-- 🔥 ACTION CARD -->
            <div class="crm-card mb-3">

                <h6 class="section-title">Update Lead</h6>
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Success"]
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["Error"]
                    </div>
                }

                <form method="post" asp-action="LeadUpdate" asp-controller="Lead" enctype="multipart/form-data">

                    <input type="hidden" asp-for="Lead.LeadId" />

                    <!-- 🟠 LEAD ACTION -->
                    <div class="crm-subcard mb-3">
                        <h6 class="sub-title">Lead Action</h6>

                        <div class="row g-3">

                            <!-- Status -->
                            <div class="col-md-4 col-12">
                                <label>Status</label>
                                <select class="crm-select" asp-for="Lead.LeadStatusId">
                                    @foreach (var status in ViewBag.LeadStatus)
                                    {
                                        <option value="@status.LeadStatusId"
                                                selected="@(Model.Lead.LeadStatusId == status.LeadStatusId)">
                                            @status.StatusName
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- Followup -->
                            <div class="col-md-4 col-12">
                                <label>Follow-up</label>
                                <input type="datetime-local" class="crm-input" asp-for="Lead.FollowupDate" />
                            </div>                       

                            <!-- Meeting -->
                            <div class="col-md-6 col-12" >
                                <label>Meeting</label>
                                <select class="crm-select" asp-for="Lead.MeetingStatus">
                                    @foreach (var item in Enum.GetValues(typeof(SalesPulseCRM.Domain.Enum.MeetingStatus)))
                                    {
                                        <option value="@((int)item)">@item</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6 col-12" id="meetingDateWrapper">
                                <label>Meeting Date & Time</label>
                                <input type="datetime-local" class="crm-input" asp-for="Lead.MeetingDateTime" />
                            </div>

                        </div>

                        <!-- Notes -->
                        <div class="mt-3">
                            <label>Notes</label>
                            <textarea class="crm-input" asp-for="Lead.NoteText" rows="2"></textarea>
                        </div>
                    </div>

                    <!-- 🔵 SALES INTELLIGENCE -->
                    <div class="crm-subcard mb-3">
                        <h6 class="sub-title">Sales Intelligence</h6>

                        <div class="row g-3">

                            <!-- Customer Intent -->
                            <div class="col-md-6 col-12">
                                <label>Customer Intent</label>
                                <select class="crm-select" asp-for="Lead.CustomerInterest">
                                    @foreach (var item in Enum.GetValues(typeof(CustomerInterest)))
                                    {
                                        <option value="@((int)item)">@item</option>
                                    }
                                </select>
                            </div>

                            <!-- Next Action (ENUM FIX) -->
                            <div class="col-md-6 col-12">
                                <label>Next Action</label>
                                <select class="crm-select" asp-for="Lead.NextAction">
                                    @foreach (var item in Enum.GetValues(typeof(NextAction)))
                                    {
                                        <option value="@((int)item)">@item</option>
                                    }
                                </select>
                            </div>

                            <!-- Budget (FIXED GRID) -->
                            <div class="col-md-6 col-12">
                                <label>Budget</label>
                                <select asp-for="Lead.Budget" class="crm-select">
                                    @foreach (Budget item in Enum.GetValues(typeof(Budget)))
                                    {
                                        <option value="@((int)item)">
                                            @item.ToDisplay()
                                        </option>
                                    }
                                </select>
                            </div>

                            <!-- Project -->
                            <div class="col-md-6 col-12">
                                <label>Project</label>
                                <select class="crm-select" asp-for="Lead.ProjectId">
                                    @foreach (var p in ViewBag.Projects)
                                    {
                                        <option value="@p.ProjectId">@p.ProjectName</option>
                                    }
                                </select>
                            </div>

                        </div>
                    </div>

                    <!-- 🟣 ATTACHMENTS -->
                    <div class="crm-subcard mb-3">
                        <h6 class="sub-title">Attachments</h6>

                        <div class="row g-3">

                            <div class="col-md-6 col-12">
                                <label>Screenshot</label>
                                <input type="file" class="crm-input" name="ScreenshotFile" />
                            </div>

                            <div class="col-md-6 col-12">
                                <label>Recording</label>
                                <input type="file" class="crm-input" name="RecordingFile" />
                            </div>

                        </div>
                    </div>

                    <button class="btn btn-primary w-100">
                        Save Update
                    </button>

                </form>

            </div>

            
        @*     <div class="timeline-tabs">

                <button class="tab active" data-type="all">All</button>
                <button class="tab" data-type="note">Notes</button>
                <button class="tab" data-type="followup">Followups</button>
                <button class="tab" data-type="assignment">Assignments</button>

            </div> *@

            <div id="leadTimelineContainer">
                @await Html.PartialAsync("_LeadTimeLine", Model.Timeline)
            </div>
        </div>

    </div>

</div>

@functions {
    public string GetTimeAgo(DateTime date)
    {
        var span = DateTime.Now - date;

        if (span.TotalSeconds < 60)
            return "Just now";

        if (span.TotalMinutes < 60)
            return $"{(int)span.TotalMinutes} min ago";

        if (span.TotalHours < 24)
            return $"{(int)span.TotalHours} hrs ago";

        if (span.TotalDays < 2)
            return "Yesterday";

        return date.ToString("dd MMM");
    }
}

  <script>
    const meetingSelect = document.querySelector('[name="Lead.MeetingStatus"]');
     const meetingWrapper = document.getElementById('meetingDateWrapper');

     function toggleMeeting() {
         if (meetingSelect.value == "2") { // Scheduled
             meetingWrapper.style.display = "block";
         } else {
             meetingWrapper.style.display = "none";
         }
     }

     // run on load
     toggleMeeting();

     // run on change
     meetingSelect.addEventListener('change', toggleMeeting);

         document.addEventListener("click", function (e) {

        const tab = e.target.closest(".timeline-tabs .tab");
        if (!tab) return;

        const wrapper = tab.closest(".timeline-wrapper");
        if (!wrapper) return;

        const tabs = wrapper.querySelectorAll(".tab");
        const items = wrapper.querySelectorAll(".crm-timeline-item");

        tabs.forEach(t => t.classList.remove("active"));
        tab.classList.add("active");

        const type = tab.dataset.type;

        items.forEach(item => {
            item.style.display =
                (type === "all" || item.dataset.type === type)
                    ? "flex"
                    : "none";
        });
    });

</script>
