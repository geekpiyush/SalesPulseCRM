@model RegisterDto
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Add User";
}

<link href="~/css/AuthController/Register.css" rel="stylesheet" asp-append-version="true"/>

<div class="container py-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h4 class="fw-semibold mb-1">Add New User</h4>
        <p class="small">Create and assign user roles easily</p>
    </div>

    <!-- SUCCESS -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success auto-hide-alert">
            @TempData["Success"]
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger auto-hide-alert">
            @ViewBag.Error
        </div>
    }
    <!-- FORM -->
    <form asp-action="Register" asp-controller="Auth" method="post">

        <div class="row g-3">

            <!-- NAME -->
            <div class="col-12 col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control input-modern" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- EMAIL -->
            <div class="col-12 col-md-6">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control input-modern" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- PHONE -->
            <div class="col-12 col-md-6">
                <label asp-for="Phone" class="form-label"></label>
                <input asp-for="Phone" class="form-control input-modern" />
            </div>

            <!-- PASSWORD -->
            <div class="col-12 col-md-6">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control input-modern" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <!-- ROLE -->
            <div class="col-12 col-md-6">
                <label asp-for="Role" class="form-label"></label>
                <select asp-for="Role" class="form-control input-modern">
                    <option value="">Select Role</option>
                    <option>Employee</option>
                    <option>Manager</option>
                    <option>Admin</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>

            <!-- MANAGER -->
            <div class="col-12 col-md-6" id="managerField">
                <label class="form-label">Manager</label>
                <select asp-for="ManagerId" class="form-control input-modern">
                    <option value="">Select Manager</option>
                    @foreach (var manager in ViewBag.Managers)
                    {
                        <option value="@manager.UserId">@manager.Name</option>
                    }
                </select>
                <span asp-validation-for="ManagerId" class="text-danger"></span>
            </div>

        </div>

        <!-- BUTTON -->
        <div class="mt-4">
            <button class="btn btn-primary px-4">Create User</button>
        </div>

    </form>

</div>
<script>
    const roleDropdown = document.querySelector('[name="Role"]');
    const managerField = document.getElementById("managerField");

    function toggleManager() {
        if (roleDropdown.value === "Employee") {
            managerField.style.display = "block";
        } else {
            managerField.style.display = "none";
        }
    }

    roleDropdown.addEventListener("change", toggleManager);
    toggleManager(); // on load

      setTimeout(() => {
        document.querySelectorAll(".auto-hide-alert").forEach(alertBox => {

            // fade + slide
            alertBox.style.transition = "all 0.5s ease";
            alertBox.style.opacity = "0";
            alertBox.style.transform = "translateY(-10px)";

            setTimeout(() => {
                alertBox.remove();
            }, 500);

        });
    }, 2000);

</script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}