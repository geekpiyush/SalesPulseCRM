@model SalesPulseCRM.Application.DTOs.LoginDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link href="~/css/AuthController/Login.css" rel="stylesheet" />
</head>

<body>

    <div class="auth-wrapper">

        <div class="auth-card">

            <div class="logo">🚀 SalesPulse</div>
            <div class="subtitle">Login to manage your CRM</div>

            <form asp-action="Login" asp-controller="Auth" method="post">

                <!-- EMAIL -->
                <div class="mb-3">
                    <input asp-for="Email" class="form-control" placeholder="Email address" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <!-- PASSWORD -->
                <div class="mb-3">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- BUTTON -->
                <button class="btn btn-login w-100">Login</button>

                <!-- LINKS -->
             @*    <div class="extra-links">
                    <a asp-action="ForgotPassword" asp-controller="Auth">Forgot Password?</a>
                </div> *@

            </form>

        </div>

    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>