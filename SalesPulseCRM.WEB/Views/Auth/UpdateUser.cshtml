@model UpdateUserViewModel

<link href="~/css/AuthController/EditUser.css" rel="stylesheet" />

<div class="mobile-container">

    <!-- HEADER -->
    <div class="mobile-header">
        <h5>Edit Employee</h5>
        <a asp-action="ViewEmployee" asp-controller="Auth" class="back-btn">←</a>
    </div>

    <form asp-action="UpdateUser" asp-controller="Auth" method="post">

        <input type="hidden" asp-for="UserId" />

        <!-- CARD -->
        <div class="form-card">

            <!-- NAME -->
            <div class="form-group">
                <label>Name</label>
                <input asp-for="Name" class="input" />
            </div>

            <!-- EMAIL -->
            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="input" />
            </div>

            <!-- PHONE -->
            <div class="form-group">
                <label>Phone</label>
                <input asp-for="Phone" class="input" />
            </div>

            <!-- ROLE -->
            <div class="form-group">
                <label>Role</label>
                <select asp-for="Role" class="input">
                    <option value="Employee">Employee</option>
                    <option value="Manager">Manager</option>
                </select>
            </div>

            <!-- MANAGER -->
            <div class="form-group">
                <label>Manager</label>
                <select asp-for="ManagerId" class="input">
                    <option value="">Select Manager</option>
                    @foreach (var m in Model.Managers)
                    {
                        <option value="@m.UserId">@m.Name</option>
                    }
                </select>
            </div>

            <!-- ACTIVE -->
            <div class="form-group toggle-group">
                <label>Status</label>
                <label class="switch">
                    <input type="checkbox" asp-for="IsActive" />
                    <span class="slider"></span>
                </label>
            </div>

        </div>

        <!-- SAVE BUTTON -->
        <button type="submit" class="save-btn">
            Update User
        </button>

    </form>

</div>
<script>
        const roleDropdown = document.querySelector('[name="Role"]');
    const managerField = document.querySelector('[name="ManagerId"]').closest('.form-group');
    const managerSelect = document.querySelector('[name="ManagerId"]');

    function toggleManager() {
    if (roleDropdown.value === "Employee") {
    managerField.style.display = "block";
    managerSelect.disabled = false;
    } else {
    managerField.style.display = "none";
    managerSelect.value = "";
    managerSelect.disabled = true;
    }
    }

    roleDropdown.addEventListener("change", toggleManager);
    toggleManager();
</script>
