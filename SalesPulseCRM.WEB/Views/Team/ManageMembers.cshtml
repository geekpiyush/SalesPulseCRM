@{
    var team = ViewBag.Team;
    var users = ViewBag.Users;
    var members = ViewBag.Members as List<int> ?? new List<int>();
}
<link href="~/css/TeamController/ManageMember.css" rel="stylesheet" asp-append-version="true" />

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<div class="container py-4">

    

    <form id="memberForm" asp-action="AddMember" method="post">
        <input type="hidden" name="teamId" value="@team.TeamId" />

        <!-- HEADER -->
        <div class="page-header mb-3">

            <div>
                <h4 class="mb-1 text-white">@team.TeamName</h4>
                <small class="text-light">
                    Managed by <span class="text-primary">@team.Manager.Name</span>
                </small>
            </div>

            <div class="header-actions">
                <button id="selectAllBtn" class="btn btn-outline-light btn-sm">
                    Select All
                </button>

                <button type="submit" id="saveBtn" class="btn btn-primary px-4">
                    Save Changes
                </button>
            </div>

        </div>
        <div class="table-wrapper">

            <table id="usersTable" class="table custom-table">

                <thead>
                    <tr>
                        <th style="width: 60px;">✔</th>
                        <th>User</th>
                        <th style="width: 150px;">Role</th>
                        <th style="width: 120px;">Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var user in users)
                    {
                        var isChecked = members.Contains(user.UserId);
                        var isManager = user.UserId == team.ManagerId;

                        <tr class="@(isManager ? "manager-row" : "")">

                            <td>
                                @if (!isManager)
                                {
                                    <input type="checkbox"
                                           name="userIds"
                                           value="@user.UserId"
                                           @(isChecked ? "checked" : "") />
                                }
                                else
                                {
                                    <i class="bi bi-lock-fill text-primary"></i>
                                }
                            </td>

                            <td class="fw-medium">
                                @user.Name
                            </td>

                            <td>
                                <span class="role-badge @user.Role.ToLower()">
                                    @user.Role
                                </span>
                            </td>

                            <td>
                                @if (isManager)
                                {
                                    <span class="badge status-badge bg-primary">Manager</span>
                                }
                                else if (isChecked)
                                {
                                    <span class="badge status-badge bg-success">Member</span>
                                }
                                else
                                {
                                    <span class="badge status-badge bg-secondary">Not Added</span>
                                }
                            </td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </form>

</div>
<div id="toast" class="custom-toast"></div>
<script>
    window.onload = function () {

        var success = '@TempData["Success"]';
        var error = '@TempData["Error"]';

        if (success && success !== '') {
            showToast(success, "success");
        }

        if (error && error !== '') {
            showToast(error, "error");
        }
    };
</script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

<script>

       $(document).ready(function () {

        let table = $('#usersTable').DataTable({
            pageLength: 5,
            lengthChange: false,
            ordering: false,
            info: false,
            language: {
                search: "",
                searchPlaceholder: "Search team members..."
            }
        });

        // 🔥 checkbox change → update UI instantly
        $(document).on("change", "input[name='userIds']", function () {

            let row = $(this).closest("tr");
            let badge = row.find(".status-badge");

            if ($(this).is(":checked")) {
                badge.removeClass("bg-secondary").addClass("bg-success").text("Member");
                row.addClass("active-row");
            } else {
                badge.removeClass("bg-success").addClass("bg-secondary").text("Not Added");
                row.removeClass("active-row");
            }
        });

        // 🔥 SELECT ALL
        $("#selectAllBtn").click(function () {
            let checkboxes = $("input[name='userIds']");
            let allChecked = checkboxes.length === checkboxes.filter(":checked").length;

            checkboxes.prop("checked", !allChecked).trigger("change");

            $(this).text(allChecked ? "Select All" : "Deselect All");
        });

    });

        function showToast(message, type) {
        let toast = document.getElementById("toast");

        toast.innerText = message;
        toast.className = "custom-toast show " + type;

        setTimeout(() => {
            toast.classList.remove("show");
        }, 2500);
    }
</script>